# Logging
LOG_LEVEL=DEBUG
LOG_FORMAT="[%(asctime)s] #%(levelname)-8s %(filename)s:%(lineno)d - %(name)s - %(message)s"

# Security settings
SECRET_KEY=secret_key
ALGORITHM=HS256

# PostgreSQL
DB_NAME=bookreviews
DB_HOST=postgresDB
DB_PORT=5432
DB_USER=admin
DB_PASSWORD=1111

# PgAdmin
PGADMIN_DEFAULT_EMAIL=admin@bookreviews.com
PGADMIN_DEFAULT_PASSWORD=1111
PGADMIN_PORT=5050

